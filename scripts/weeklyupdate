#!/usr/bin/env bash
# Jobs that need running weekly
#set -x
#set -v

set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

source consts

source ../../shlib/deployfns
read_conf "../conf/general"

INDEX="$(mktemp "${TMPDIR:-/tmp}/all-titles-in-ns0.XXXXXX")"
INDEX_GZ="${INDEX}.gz"

cleanup() {
	rm -f "$INDEX_GZ" "$INDEX"
}
trap cleanup EXIT

# Get new Wikipedia titles database
# looks for "enwiki/ in the page (with a leading quote) so it doesn't pick up "tenwiki"
DUMPDATE="$(curl --fail --location --silent --show-error "https://dumps.wikimedia.org/backup-index.html" \
	| grep -oE '"enwiki/[0-9]{8}/' \
	| head -n 1 \
	| grep -oE '[0-9]{8}')"
if [[ -z "$DUMPDATE" ]]; then
	echo "Could not determine Wikipedia dump date" >&2
	exit 1
fi
echo "Wikipedia dump date $DUMPDATE"

echo "Downloading to ${INDEX}"
URL="https://dumps.wikimedia.org/enwiki/${DUMPDATE}/enwiki-${DUMPDATE}-all-titles-in-ns0.gz"

curl --fail --location --silent --show-error -o "$INDEX_GZ" "${URL}"
ls -lh "$INDEX_GZ"
gunzip "$INDEX_GZ"

MYSQL=(
	mysql
	--local-infile=1
	-u "${DB_USER}"
	"--password=${DB_PASSWORD}"
	--host="${DB_HOST}"
	"${DB_NAME}"
)

echo "load data local infile '$INDEX' ignore into table titles;" | "${MYSQL[@]}"
"${MYSQL[@]}" < wikipedia-exceptions

# Compact Xapian database
./compactsearchdb


#Full database:
#http://download.wikimedia.org/enwiki/latest/enwiki-latest-pages-articles.xml.bz2
