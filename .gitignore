# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# App specific ignores
www/docs/images/mps/*.jpg
www/docs/images/mpsL/*.jpg
www/docs/images/mpsXL/*.jpg
www/docs/rss/mp/*.rdf
www/docs/debates/debates.rss
www/docs/senate/senate.rss
www/docs/sitemap.xml
www/docs/sitemaps/*
www/docs/regmem/scan/*.pdf

# Lockfiles
scripts/morningupdate-lockfile
scripts/run-with-lockfile
scripts/rssgenerate-lockfile

scripts/alerts-lastsent

# Local configuration
conf/general

# composer output
/vendor/

# docker volumes
_mysqldata/*
_xapiandb/*

# test and coverage reports
phpcs-report.json
.phpunit.result.cache
coverage/*

# Ignore all logfiles and tempfiles.
/log
*.log
/tmp

# Temp files
*.bak

# Used by direnv / dotenv library to load environment variables.
/.env*

# Backups
db/backups

# local override of docker compose config
/docker-compose.override.yml

# IDE and editor files
/.aider*
/.idea
/.vscode*

# Ignore vim files:
*~
*.swp
*.swo

# Ignore patch files
*.patch
*.rej

# macOS:
.DS_Store
.AppleDouble
.LSOverride

# Windows:
Thumbs.db
ehthumbs.db
Desktop.ini
