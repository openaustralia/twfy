{
    "name": "openaustralia/twfy",
    "description": "Web Application component for Open Australia (twfy module)",
    "type": "project",
    "license": "BSD-3-Clause",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.3.0",
        "open-telemetry/sdk": "^1.4",
        "open-telemetry/exporter-otlp": "^1.4",
        "guzzlehttp/guzzle": "^7.9",
        "php-http/guzzle7-adapter": "^1.1"
    },
    "scripts": {
      "git-hooks": "test -d .git && git config core.hooksPath git-hooks || exit 0",
      "phpcs": "./vendor/bin/phpcs --standard=phpcs.xml .",
      "post-install-cmd": [
          "@git-hooks"
      ],
      "post-update-cmd": [
          "@git-hooks"
      ]
    },
    "config": {
        "bin-dir": "vendor/bin/",
        "audit": {
            "abandoned": "report"
        },
        "platform": {
            "php": "8.3.16"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    },
    "require-dev": {
        "drupal/coder": "^8.3",
        "phpunit/phpunit": "^11",
        "squizlabs/php_codesniffer": "^3.13",
        "vimeo/psalm": "^6.16",
        "robmorgan/phinx": "^0.16.11"
    }
}
